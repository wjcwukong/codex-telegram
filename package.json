{
  "name": "codex-telegram",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "start": "./scripts/with-node.sh --import tsx server.ts",
    "dev": "./scripts/with-node.sh --import tsx --watch server.ts",
    "connect": "./scripts/with-node.sh --import tsx connect.ts",
    "test": "./scripts/with-node.sh ./node_modules/vitest/vitest.mjs run",
    "test:watch": "./scripts/with-node.sh ./node_modules/vitest/vitest.mjs",
    "typecheck": "./scripts/with-node.sh ./node_modules/typescript/bin/tsc --noEmit"
  },
  "dependencies": {
    "@types/ws": "^8.18.1",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^16.4.0",
    "grammy": "^1.21.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.2"
  }
}
